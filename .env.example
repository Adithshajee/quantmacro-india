# SQLite Database File Path
DB_PATH=data/project.db

# API Key for news ingestion (optional RSS feed is used as fallback)
NEWS_API_KEY=your_news_api_key_here

# Hugging Face sentiment model (defaults to ProsusAI/finbert)
MODEL_NAME=ProsusAI/finbert

# Targeting Sector Indices (Comma-separated)
TARGET_SECTORS=BSE_BANKEX,BSE_IT,BSE_ENERGY,BSE_SENSEX

# LLM Reasoning Engine API Keys (At least one is required for AI summaries)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# FastAPI Backend Service URL for Streamlit
API_URL=http://localhost:8000
